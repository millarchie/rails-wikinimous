<div class="container p-3 mt-3">
  <h1 class="mt-3">Edit an Article</h1>
  <!-- <form action="/articles" method="post"> -->
      <%= simple_form_for @article do |f| %>
        <%= f.input :title %>
        <%= f.input :content %>
        <%= f.submit class: 'btn btn-success my-2 col-2' %>
      <% end %>
      <%= link_to "Home", articles_path, class: 'btn btn-primary my-2 col-2' %>
</div>
